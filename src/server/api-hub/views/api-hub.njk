{% extends 'layouts/page.njk' %}

{% block content %}
  {{ appHeading({
    text: heading,
    caption: caption
  }) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      <div class="govuk-body" data-testid="app-page-body">

        <table class="govuk-table">
          <caption class="govuk-table__caption govuk-table__caption--m">Available APIs</caption>
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header">API</th>
              <th scope="col" class="govuk-table__header">Team</th>
              <th scope="col" class="govuk-table__header">Format</th>
              <th scope="col" class="govuk-table__header"></th>
            </tr>
          </thead>
          <tbody class="govuk-table__body">

          {%  for api in apis %}
          <tr class="govuk-table__row">
            <th scope="row" class="govuk-table__header">{{ api.id }}</th>
            <td class="govuk-table__header">
              <ul class="govuk-list">
                {% for team in api.teams %}<li>{{ team }}</li>{% endfor %}
              </ul>
            </td>
            <td class="govuk-table__cell">
              <strong class="govuk-tag app-tag govuk-tag--blue" data-testid="govuk-tag">
                {{ api.docType }}
              </strong>
            </td>
            <td class="govuk-table__cell">
              {%  if api.enabled %}
                <a class="govuk-link" href="{{ api.link }}">View</a>
              {% else %}
                <strong class="govuk-tag app-tag govuk-tag--grey" data-testid="govuk-tag">Offline</strong>
              {% endif %}
            </td>
          </tr>
          {%  endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>

{% endblock %}
